  "scripts": {
    "dev": "vite",
    "dev:network": "vite --host",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate:icons": "node generate-icons.js",
    "build:android": "npm run build && npx cap sync android",
    "build:android:local": "JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home vite build --mode android && npx cap sync android",
    "open:android": "npx cap open android",
    "sync:android": "npx cap sync android",
    "run:android": "npm run build:android && npm run open:android",
    "run:android:local": "npm run build:android:local && JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home npx cap run android --target R9RY501LW3Y",
    "dev:android": "JAVA_HOME=/opt/homebrew/opt/openjdk@21 npx cap run android --live-reload --host 192.168.1.51 --port 5173 --target R9RY501LW3Y"
  },
